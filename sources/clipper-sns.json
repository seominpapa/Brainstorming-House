{
	"schemaVersion": "0.1.0",
	"name": "SNS 소스",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "source_type",
			"value": "sns",
			"type": "text"
		},
		{
			"name": "platform",
			"value": "{{site}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{author|split:\", \"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "clipped",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings/sns",
			"type": "multitext"
		},
		{
			"name": "wiki_status",
			"value": "unprocessed",
			"type": "text"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{date}}_{{title}}",
	"path": "sources/sns"
}
