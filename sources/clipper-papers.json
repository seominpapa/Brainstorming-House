{
	"schemaVersion": "0.1.0",
	"name": "논문·보고서",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "source_type",
			"value": "paper",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{author|split:\", \"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "clipped",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings/paper",
			"type": "multitext"
		},
		{
			"name": "wiki_status",
			"value": "unprocessed",
			"type": "text"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{date:YYYY-MM-DD}}_{{title}}",
	"path": "sources/papers"
}
